# 前端
# API 基地址（默认 /api，建议由 Nginx 反代到后端）
VITE_API_BASE_URL=/api

# Bella 头像
VITE_ASSISTANT_AVATAR_URL=/bella-avatar.png

# Bella 聊天接口超时（毫秒），默认 600000（10 分钟）
VITE_ASSISTANT_CHAT_TIMEOUT_MS=600000

# （可选）后端 assistant 鉴权 key
# 注意：这会被打包进前端静态资源，适合“自用/私有部署”。
# 公网产品请用真正的用户登录/会话鉴权，不要把固定密钥下发到浏览器。
VITE_BACKEND_API_KEY=

