# Frontend environment template
# Legend:
# - [REQUIRED] Must be set when the related feature is used.
# - [OPTIONAL] Can be left empty to use default behavior.
# - [RECOMMENDED EMPTY] Keep empty unless you explicitly need it.

# API base URL (default `/api`, usually reverse-proxied to backend via Nginx).
# [OPTIONAL] Keep `/api` for standard local/production setups.
VITE_API_BASE_URL=/api

# Bella avatar URL.
# [OPTIONAL] Empty uses frontend default avatar asset logic.
VITE_ASSISTANT_AVATAR_URL=/bella-avatar.png

# Bella chat request timeout in milliseconds. Default: 600000 (10 minutes).
# [OPTIONAL] Empty lets frontend use default timeout.
VITE_ASSISTANT_CHAT_TIMEOUT_MS=600000

# Optional backend assistant auth key.
# Warning: this value is bundled into frontend static assets, suitable only for
# private/self-hosted deployments. For public products, use real user auth/session
# instead of exposing a fixed key in the browser.
# [RECOMMENDED EMPTY] If empty, frontend does not send `x-api-key`.
VITE_BACKEND_API_KEY=

