# Copy to `backend/.env`. The backend loads this file when the process cwd is `backend/`
# (`npm run dev`, `npm run start`, `./run-dev.sh`). Do not commit real secrets.
#
# Legend:
# - [REQUIRED] must be set for the referenced feature to work.
# - [OPTIONAL] may be omitted; default/fallback behavior is described.
# - [LEAVE EMPTY] keep empty unless you intentionally override.

# --- Server ---
# [OPTIONAL] Backend listen port. Default shown below.
PORT=3001
# [OPTIONAL] CORS origin allowlist for browser frontend.
CORS_ORIGIN=http://localhost:5173
# [OPTIONAL] External backend base URL used in generated links.
BACKEND_BASE_URL=http://localhost:3001
# [LEAVE EMPTY] Trust proxy setting for reverse-proxy deployments.
# Empty -> Express default (no trust proxy).
TRUST_PROXY=
# [OPTIONAL] JSON body parser limit (e.g. 2mb).
# Empty -> app default.
JSON_BODY_LIMIT=

# --- PostgreSQL (Prisma + optional gbrain; same vars for docker compose) ---
# Easiest: set the password (and optional overrides) below. Leave DATABASE_URL empty
# and the server builds it automatically. Same file is used by:
#   docker compose --env-file backend/.env up -d   (repo root)   OR   npm run docker:db
# [OPTIONAL] DB user for local/docker path.
POSTGRES_USER=bella
# [REQUIRED for local/docker DB path] must be set (non-empty).
POSTGRES_PASSWORD=
# [OPTIONAL] DB name for local/docker path.
POSTGRES_DB=bella
# [OPTIONAL] DB host for local/docker path.
POSTGRES_HOST=127.0.0.1
# Host port mapped by docker-compose.yml (127.0.0.1 only, not the container's 5432).
# [OPTIONAL] DB host port used by local compose.
BELLA_PG_HOST_PORT=55432
# Optional: set explicitly if you do not use the auto-build (e.g. managed cloud DB).
# If this is empty or unset, the server and `npm run prisma:deploy` build a URL from POSTGRES_* above.
# [OPTIONAL] Full connection URL override.
# Empty -> auto-build from POSTGRES_* and BELLA_PG_HOST_PORT.
# DATABASE_URL=

# --- gbrain companion memory (CLI subprocess) ---
# Semantics (run mode A/B/C, GBRAIN_PUT_* vs World/chat OpenAI): docs/COMPANION_AUTH_GBRAIN.md §1.2.1–§1.2.2.
# After `gbrain init` with the same DATABASE_URL as Bella, uncomment and restart the backend:
# GBRAIN_ENABLED=1
# GBRAIN_BIN=gbrain
# GBRAIN_TIMEOUT_MS=15000
# `gbrain put` timeout (ms). Default 120000. Only raise if you set GBRAIN_PUT_WITH_EMBED=1 (full OpenAI embedding on each put).
# GBRAIN_PUT_TIMEOUT_MS=120000
# Set to 1 for full embedding on each `gbrain put` (slow if API is bad). Default: ephemeral HOME + dummy OpenAI URL so ~/.gbrain/config.json keys do not hang `put`.
# GBRAIN_PUT_WITH_EMBED=
# world: try gbrain query then keyword search; china: keyword only. Set 0 to skip query in world too.
# GBRAIN_USE_QUERY_WORLD=1
# Notes:
# - [LEAVE EMPTY] all GBRAIN_* vars if you don't use companion memory.
# - If GBRAIN_ENABLED is empty/0: gbrain reads/writes are skipped.

# --- Bella auth / sessions ---
# BELLA_SESSION_SECURE=1
# BELLA_SESSION_DAYS=30
# BELLA_ALLOW_REGISTER=1
# BELLA_PASSWORD_RESET_TOKEN=
# All auth/session vars above are [OPTIONAL]; empty -> backend defaults.

# --- API protection (optional; when set, assistant routes require x-api-key) ---
# [LEAVE EMPTY] for normal auth/session mode.
# [OPTIONAL] set for private deployments requiring static `x-api-key`.
BACKEND_API_KEY=

# --- Assistant / OpenClaw ---
# [OPTIONAL] Provider selection. `openai` default.
ASSISTANT_CHAT_PROVIDER=openai
# [OPTIONAL] Base text model when provider path uses this field.
ASSISTANT_CHAT_MODEL=gpt-4o-mini
ASSISTANT_UPLOAD_MAX_BYTES=
OPENCLAW_AGENT_ID=main
OPENCLAW_WORKSPACE=
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_GATEWAY_AUTH=
OPENCLAW_GATEWAY_TIMEOUT_MS=
OPENCLAW_MODEL=
OPENCLAW_MODEL_CHINA=
OPENCLAW_MODEL_WORLD=
OPENCLAW_MODEL_FALLBACKS=
OPENCLAW_MAX_TOKENS=
OPENCLAW_MAX_CONTINUATIONS=
OPENCLAW_SEARCH_BROWSER_FALLBACK_TO_BING=1
OPENCLAW_ENABLE_WEB_SEARCH=0
OPENCLAW_ENABLE_WEB_FETCH=0
OPENCLAW_RATE_LIMIT_COOLDOWN_MS=
ASSISTANT_RATE_LIMIT_WINDOW_MS=
ASSISTANT_RATE_LIMIT_MAX=
# Notes:
# - OpenClaw path requires reachable OPENCLAW_GATEWAY_URL.
# - OPENCLAW_GATEWAY_TOKEN:
#   [REQUIRED] only if gateway auth is enabled.
#   [LEAVE EMPTY] if gateway runs without token auth.

# --- Assistant / Hermes ---
# Hermes repo checkout path. Default (if empty) resolves to: $HOME/projects/hermes
HERMES_ROOT=
# Optional: venv used to run `python -m hermes_cli.main`
HERMES_VENV=
# Optional: force Hermes provider/model without interactive setup.
# Example:
#   HERMES_PROVIDER=openrouter
#   HERMES_MODEL=openai/gpt-5-mini
HERMES_PROVIDER=
HERMES_MODEL=
# Optional explicit command (highest priority), e.g.:
# HERMES_CMD=/home/<user>/.venvs/hermes/bin/python -m hermes_cli.main
HERMES_CMD=
# Optional explicit Hermes migrate command used by framework full_migrate
# (recommended to avoid PATH issues, e.g. ENOENT):
# BELLA_HERMES_MIGRATE_CMD=/home/<user>/.local/bin/hermes
BELLA_HERMES_MIGRATE_CMD=
# Optional timeout for Hermes subprocess.
HERMES_TIMEOUT_MS=120000
# Notes:
# - HERMES_ROOT [OPTIONAL]: empty -> defaults to $HOME/projects/hermes.
# - HERMES_PROVIDER / HERMES_MODEL [OPTIONAL]: empty -> Hermes internal defaults/config.
# - Hermes runtime needs at least one valid provider credential from section below.

# --- LLM provider keys (set what you use) ---
# Hermes/OpenClaw common:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_TOKEN=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=
# Existing project providers:
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com
DOUBAO_MODEL=
DOUBAO_ENDPOINT_ID=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=
# Notes:
# - Provider keys are feature-dependent [REQUIRED]:
#   fill only the provider(s) you use.
# - Unused provider keys should stay empty.

# --- Bella outer / intent (optional overrides) ---
BELLA_OUTER_PROVIDER_CHINA=
BELLA_OUTER_PROVIDER_WORLD=
BELLA_OUTER_FALLBACK_PROVIDER_CHINA=
BELLA_OUTER_FALLBACK_PROVIDER_WORLD=
BELLA_DOUBAO_API_KEY=
BELLA_DOUBAO_BASE_URL=
BELLA_DOUBAO_MODEL=
BELLA_GEMINI_API_KEY=
BELLA_GEMINI_MODEL=
BELLA_GEMINI_BASE_URL=
BELLA_INTENT_PROVIDER_CHINA=
BELLA_INTENT_PROVIDER_WORLD=
BELLA_ROUTER_MODE=hybrid
BELLA_INTENT_CONF_THRESHOLD=
BELLA_INTENT_MODEL_CHINA=
BELLA_INTENT_MODEL_WORLD=
# [OPTIONAL] Empty -> project defaults for outer/intent providers/models.

# --- Bella short-term session memory (not gbrain) ---
BELLA_MEMORY_TURNS=
BELLA_MEMORY_MAX_SESSIONS=
BELLA_MEMORY_FILE=
# [OPTIONAL] Empty -> built-in defaults and default data file location.

# --- Media / weather ---
MEDIA_IMAGE_PROVIDER=
MEDIA_VIDEO_PROVIDER=
ASSISTANT_IMAGE_PROVIDER=
ASSISTANT_VIDEO_PROVIDER=
DOUBAO_IMAGE_MODEL_ID=
DOUBAO_VIDEO_MODEL_ID=
ASSISTANT_REFERENCE_IMAGE_PATH=
ASSISTANT_REFERENCE_IMAGE_URL=
WEATHER_TIMEOUT=
WEATHER_PROXY=
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=
# [OPTIONAL] Keep media/weather/proxy vars empty unless your deployment needs overrides.

# --- Optional keys sometimes mirrored in backend/.env ---
# `VITE_*` is normally for `frontend/.env` / `.env.local` (Vite); the Node backend does not read it.
# VITE_ASSISTANT_CHAT_TIMEOUT_MS=
# MINIMAX_API_KEY=   # optional legacy; not referenced under backend/src

# --- Star Office (optional) ---
STAR_OFFICE_BASE_URL=http://127.0.0.1:19000
STAR_OFFICE_MODULE_ENABLED=0
STAR_OFFICE_SYNC_ENABLED=0
STAR_OFFICE_SYNC_MIN_INTERVAL_MS=1000
STAR_OFFICE_PANELS=
# [LEAVE EMPTY or 0] if you don't deploy Star Office.

# --- iFlytek (optional) ---
IFLY_APP_ID=
IFLY_ACCESS_KEY_ID=
IFLY_API_SECRET=
# [LEAVE EMPTY] unless you use iFlytek ASR integration.
