# Copy to `backend/.env`. The backend loads this file when the process cwd is `backend/`
# (`npm run dev`, `npm run start`, `./run-dev.sh`). Do not commit real secrets.

# --- Server ---
PORT=3001
CORS_ORIGIN=http://localhost:5173
BACKEND_BASE_URL=http://localhost:3001
TRUST_PROXY=
JSON_BODY_LIMIT=

# --- PostgreSQL (Prisma + optional gbrain; same vars for docker compose) ---
# Easiest: set the password (and optional overrides) below. Leave DATABASE_URL empty
# and the server builds it automatically. Same file is used by:
#   docker compose --env-file backend/.env up -d   (repo root)   OR   npm run docker:db
POSTGRES_USER=bella
POSTGRES_PASSWORD=
POSTGRES_DB=bella
POSTGRES_HOST=127.0.0.1
# Host port mapped by docker-compose.yml (127.0.0.1 only, not the container's 5432).
BELLA_PG_HOST_PORT=55432
# Optional: set explicitly if you do not use the auto-build (e.g. managed cloud DB).
# If this is empty or unset, the server and `npm run prisma:deploy` build a URL from POSTGRES_* above.
# DATABASE_URL=

# --- gbrain companion memory (CLI subprocess) ---
# Semantics (run mode A/B/C, GBRAIN_PUT_* vs World/chat OpenAI): docs/COMPANION_AUTH_GBRAIN.md §1.2.1–§1.2.2.
# After `gbrain init` with the same DATABASE_URL as Bella, uncomment and restart the backend:
# GBRAIN_ENABLED=1
# GBRAIN_BIN=gbrain
# GBRAIN_TIMEOUT_MS=15000
# `gbrain put` timeout (ms). Default 120000. Only raise if you set GBRAIN_PUT_WITH_EMBED=1 (full OpenAI embedding on each put).
# GBRAIN_PUT_TIMEOUT_MS=120000
# Set to 1 for full embedding on each `gbrain put` (slow if API is bad). Default: ephemeral HOME + dummy OpenAI URL so ~/.gbrain/config.json keys do not hang `put`.
# GBRAIN_PUT_WITH_EMBED=
# world: try gbrain query then keyword search; china: keyword only. Set 0 to skip query in world too.
# GBRAIN_USE_QUERY_WORLD=1

# --- Bella auth / sessions ---
# BELLA_SESSION_SECURE=1
# BELLA_SESSION_DAYS=30
# BELLA_ALLOW_REGISTER=1
# BELLA_PASSWORD_RESET_TOKEN=

# --- API protection (optional; when set, assistant routes require x-api-key) ---
BACKEND_API_KEY=

# --- Assistant / OpenClaw ---
ASSISTANT_CHAT_PROVIDER=openai
ASSISTANT_CHAT_MODEL=gpt-4o-mini
ASSISTANT_UPLOAD_MAX_BYTES=
OPENCLAW_AGENT_ID=main
OPENCLAW_WORKSPACE=
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_GATEWAY_AUTH=
OPENCLAW_GATEWAY_TIMEOUT_MS=
OPENCLAW_MODEL=
OPENCLAW_MODEL_CHINA=
OPENCLAW_MODEL_WORLD=
OPENCLAW_MODEL_FALLBACKS=
OPENCLAW_MAX_TOKENS=
OPENCLAW_MAX_CONTINUATIONS=
OPENCLAW_SEARCH_BROWSER_FALLBACK_TO_BING=1
OPENCLAW_ENABLE_WEB_SEARCH=0
OPENCLAW_ENABLE_WEB_FETCH=0
OPENCLAW_RATE_LIMIT_COOLDOWN_MS=
ASSISTANT_RATE_LIMIT_WINDOW_MS=
ASSISTANT_RATE_LIMIT_MAX=

# --- LLM provider keys (set what you use) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com
DOUBAO_MODEL=
DOUBAO_ENDPOINT_ID=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=

# --- Bella outer / intent (optional overrides) ---
BELLA_OUTER_PROVIDER_CHINA=
BELLA_OUTER_PROVIDER_WORLD=
BELLA_OUTER_FALLBACK_PROVIDER_CHINA=
BELLA_OUTER_FALLBACK_PROVIDER_WORLD=
BELLA_DOUBAO_API_KEY=
BELLA_DOUBAO_BASE_URL=
BELLA_DOUBAO_MODEL=
BELLA_GEMINI_API_KEY=
BELLA_GEMINI_MODEL=
BELLA_GEMINI_BASE_URL=
BELLA_INTENT_PROVIDER_CHINA=
BELLA_INTENT_PROVIDER_WORLD=
BELLA_ROUTER_MODE=hybrid
BELLA_INTENT_CONF_THRESHOLD=
BELLA_INTENT_MODEL_CHINA=
BELLA_INTENT_MODEL_WORLD=

# --- Bella short-term session memory (not gbrain) ---
BELLA_MEMORY_TURNS=
BELLA_MEMORY_MAX_SESSIONS=
BELLA_MEMORY_FILE=

# --- Media / weather ---
MEDIA_IMAGE_PROVIDER=
MEDIA_VIDEO_PROVIDER=
ASSISTANT_IMAGE_PROVIDER=
ASSISTANT_VIDEO_PROVIDER=
DOUBAO_IMAGE_MODEL_ID=
DOUBAO_VIDEO_MODEL_ID=
ASSISTANT_REFERENCE_IMAGE_PATH=
ASSISTANT_REFERENCE_IMAGE_URL=
WEATHER_TIMEOUT=
WEATHER_PROXY=
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=

# --- Optional keys sometimes mirrored in backend/.env ---
# `VITE_*` is normally for `frontend/.env` / `.env.local` (Vite); the Node backend does not read it.
# VITE_ASSISTANT_CHAT_TIMEOUT_MS=
# MINIMAX_API_KEY=   # optional legacy; not referenced under backend/src

# --- Star Office (optional) ---
STAR_OFFICE_BASE_URL=http://127.0.0.1:19000
STAR_OFFICE_MODULE_ENABLED=0
STAR_OFFICE_SYNC_ENABLED=0
STAR_OFFICE_SYNC_MIN_INTERVAL_MS=1000
STAR_OFFICE_PANELS=

# --- iFlytek (optional) ---
IFLY_APP_ID=
IFLY_ACCESS_KEY_ID=
IFLY_API_SECRET=
