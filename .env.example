# Environment templates for the `yours` monorepo
#
# - Backend (Node/Express, Prisma, gbrain subprocess): copy `backend/.env.example`
#   to `backend/.env` and edit there. `dotenv` loads `backend/.env` when you run
#   npm scripts from the `backend/` directory (see `backend/run-dev.sh`).
# - Frontend (Vite): copy the variables below into `frontend/.env` or
#   `frontend/.env.local`.
#
# Legend:
# - [REQUIRED] must be set for the referenced feature to work.
# - [OPTIONAL] can be omitted; default/fallback behavior is documented.
# - [LEAVE EMPTY] keep empty unless you explicitly need to override behavior.

# --- Frontend (Vite) — place in frontend/.env or frontend/.env.local ---
# [OPTIONAL] API base URL. Default `/api` (recommended with reverse proxy).
# Leave empty or keep `/api` for standard local/prod setups.
VITE_API_BASE_URL=/api
# [LEAVE EMPTY] Optional static API key header for private/self-hosted use.
# If empty: frontend sends no `x-api-key`.
# For public products: keep empty and use real auth/session instead.
VITE_BACKEND_API_KEY=
# [OPTIONAL] Custom Bella avatar URL. If empty: frontend default asset logic applies.
VITE_ASSISTANT_AVATAR_URL=
# [OPTIONAL] Chat timeout in ms. If empty: frontend defaults to 600000 (10 min).
VITE_ASSISTANT_CHAT_TIMEOUT_MS=
# [OPTIONAL] Max upload bytes hint for UI. If empty: backend-side limits still apply.
VITE_ASSISTANT_UPLOAD_MAX_BYTES=
# [OPTIONAL] Star Office UI URL when optional subsystem is enabled.
VITE_STAR_OFFICE_URL=http://127.0.0.1:19000
# [LEAVE EMPTY] Feature flag for Star Office shell.
# If empty/0: Star Office UI entry remains disabled.
VITE_ENABLE_STAR_OFFICE_UI=

# --- Backend ---
# See `backend/.env.example` for the full list (DATABASE_URL, GBRAIN_*, OpenClaw, LLM keys, etc.).
